generator client {
  provider      = "prisma-client-js"
  // output       = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------
// Enums (Mapped from your migrations)
// --------------------------------------

enum UserRole {
  ADMIN
  USER
}

enum ShopStatus {
  PENDING
  REJECTED
  CLOSED
  OPEN
  SUSPENDED
}

enum MealCategory {
  MEAL
  SNACK
  DRINK
  DESSERT
  TOOL
  SAUCE
}

enum StaffRole {
  OWNER
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  READY
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum TransactionType {
  credit
  debit
}

// --------------------------------------
// Models
// --------------------------------------

model User {
  id               String    @id @default(cuid())
  name             String
  email            String?   @unique
  phone            String?   @unique
  image            String?
  googleId         String?   @unique @map("google_id")
  emailVerified    DateTime? @map("email_verified_at")
  password         String?
  role             UserRole  @default(USER)
  remindPhoneSetup Boolean   @default(true) @map("remind_phone_setup")
  rememberToken    String?   @map("remember_token")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  cartItems CartItem[]
  userRoles UserShopRole[]
  orders    Order[]
  accounts  Account[]
  sessions  Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Shop {
  id                 String     @id @default(cuid())
  name               String     @unique
  address            String
  phone              String
  profileImage       String?    @map("profileImage")
  description        String
  status             ShopStatus @default(PENDING)
  fixedTimePickup    Boolean    @default(false) @map("fixed_time_pickup")
  orderCutoffMinutes Int        @default(0) @map("order_cutoff_minutes")
  dailyOrderLimit    Int        @default(0) @map("daily_order_limit")
  showNewMenuSection Boolean    @default(false) @map("show_new_menu_section")
  isUsingTimePickup  Boolean    @default(true) @map("is_using_time_pickup")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  // Relations
  meals          Meal[]
  userRoles      UserShopRole[]
  wallet         ShopWallet?
  orders         Order[]
  pickupTimes    PickupTime[]
  pickupLabels   PickupLabel[]
  orderSchedules OrderSchedule[]

  orderScheduleMode OrderScheduleMode @default(OFF) @map("order_schedule_mode")

  @@map("shops")
}

model OrderSchedule {
  id        String   @id @default(cuid())
  shopId    String   @map("shop_id")
  day       String   @db.VarChar(10) // Monday, Tuesday, etc.
  startTime String   @map("start_time") @db.VarChar(5) // HH:MM
  endTime   String   @map("end_time") @db.VarChar(5) // HH:MM
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("order_schedules")
}

enum OrderScheduleMode {
  OFF
  ON
}

model PickupTime {
  id        String   @id @default(cuid())
  shopId    String   @map("shop_id")
  time      String   @db.VarChar(5) // Format HH:MM
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("pickup_times")
}

model PickupLabel {
  id        String   @id @default(cuid())
  shopId    String   @map("shop_id")
  label     String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("pickup_labels")
}

model UserShopRole {
  id              String    @id @default(cuid())
  shopId          String    @map("shop_id")
  userId          String    @map("user_id")
  role            StaffRole
  getNotification Boolean   @default(true) @map("getNotification")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@map("user_roles")
}

model Meal {
  id            String       @id @default(cuid())
  shopId        String       @map("shop_id")
  name          String
  description   String
  price         Decimal      @db.Decimal(10, 2)
  discountPrice Decimal      @default(0) @db.Decimal(10, 2)
  category      MealCategory @default(MEAL)
  isAvailable   Boolean      @default(true) @map("isAvailable")
  orderNumber   Int          @default(0) @map("order_number")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  allowNotes    Boolean      @default(false) @map("allowNotes")

  // Relations
  shop         Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  optionGroups MealOptionGroup[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  images       MealImage[]

  @@map("meals")
}

model MealImage {
  id        String   @id @default(cuid())
  mealId    String   @map("meal_id")
  imagePath String   @map("image_path")
  order     Int      @default(0)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("meal_images")
}

model MealOptionGroup {
  id         String   @id @default(cuid())
  mealId     String   @map("meal_id")
  name       String
  isMultiple Boolean  @default(false) @map("is_multiple")
  isRequired Boolean  @default(false) @map("is_required")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  meal   Meal              @relation(fields: [mealId], references: [id], onDelete: Cascade)
  values MealOptionValue[]

  @@map("meal_option_groups")
}

model MealOptionValue {
  id                String   @id @default(cuid())
  mealOptionGroupId String   @map("meal_option_group_id")
  name              String
  price             Decimal  @default(0) @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  group           MealOptionGroup  @relation(fields: [mealOptionGroupId], references: [id], onDelete: Cascade)
  cartItemOptions CartItemOption[]

  @@map("meal_option_values")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  mealId    String   @map("meal_id")
  quantity  Int      @default(1)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal    Meal             @relation(fields: [mealId], references: [id], onDelete: Cascade)
  options CartItemOption[]

  @@map("cart_items")
}

model CartItemOption {
  id                String   @id @default(cuid())
  cartItemId        String   @map("cart_item_id")
  mealOptionValueId String   @map("meal_option_value_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  cartItem        CartItem        @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  mealOptionValue MealOptionValue @relation(fields: [mealOptionValueId], references: [id], onDelete: Cascade)

  @@unique([cartItemId, mealOptionValueId])
  @@map("cart_item_options")
}

model ShopWallet {
  id             String   @id @default(cuid())
  shopId         String   @unique @map("shop_id")
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  pendingBalance Decimal  @default(0) @map("pending_balance") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("shop_wallets")
}

model Order {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  shopId      String      @map("shop_id")
  orderStatus OrderStatus @default(PENDING) @map("order_status")
  pickupDate  DateTime?   @map("pickup_date")
  pickupLabel String?     @map("pickup_label") @db.VarChar(100)

  paymentStatus         PaymentStatus @default(PENDING) @map("payment_status")
  midtransOrderId       String        @unique @map("midtrans_order_id") @db.VarChar(50)
  midtransTransactionId String?       @map("midtrans_transaction_id") @db.VarChar(50)
  paymentMethod         String?       @map("payment_method") @db.VarChar(30)
  snapToken             String?       @map("snap_token") @db.VarChar(255)
  totalAmount           Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentTime           DateTime?     @map("payment_time")
  rawMidtransResponse   Json?         @map("raw_midtrans_response")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  transactions Transaction[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  mealId    String?  @map("meal_id")
  mealName  String   @map("meal_name") @db.VarChar(100)
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  notes     String?
  rate      Int?
  reviewMsg String?  @map("review_msg") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order   Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  meal    Meal?             @relation(fields: [mealId], references: [id], onDelete: SetNull)
  options OrderItemOption[]

  @@map("order_items")
}

model OrderItemOption {
  id          String   @id @default(cuid())
  orderItemId String   @map("order_item_id")
  optionName  String   @map("option_name") @db.VarChar(100)
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("order_item_options")
}

model Transaction {
  id          String          @id @default(cuid())
  walletId    String          @map("wallet_id")
  orderId     String?         @map("order_id")
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  proofImage  String?         @map("proof_image")
  description String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  wallet ShopWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order  Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([orderId])
  @@map("transactions")
}
